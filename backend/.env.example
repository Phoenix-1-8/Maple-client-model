# ---- Maple backend configuration ----

# Database. Default (laptop, zero-config): SQLite file.
# DATABASE_URL=sqlite:///./maple.db
# Postgres (docker-compose):
# DATABASE_URL=postgresql+psycopg2://maple:maple@db:5432/maple

# Redis queue (optional). Leave empty to run scrape jobs synchronously.
# REDIS_URL=redis://localhost:6379/0

# Seed a full mock market on startup.
SEED_ON_STARTUP=true

# Reproducibility: pin the random seed and the "as of" date for stable demos.
MAPLE_MOCK_SEED=42
# MAPLE_AS_OF=2026-06-11

# How many days of synthetic history to generate for trend charts.
MAPLE_HISTORY_DAYS=60

# CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Override business config from a JSON file (premiums, costs, grade map, ...).
# MAPLE_CONFIG_FILE=maple_config.json

# ---- Live scraping (optional) ----
# BrightData Web Unlocker / proxy for Playwright. When unset, scrapers fall
# back to mock data so the pilot always works.
# BRIGHTDATA_API_KEY=
# BRIGHTDATA_WSS=wss://brd-customer-XXX:pass@brd.superproxy.io:9222
